datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  username            String?       @unique
  passwordHash        String        @map("password_hash")
  firstName           String?       @map("first_name")
  lastName            String?       @map("last_name")
  displayName         String?       @map("display_name")
  phone               String?
  avatar              String?
  status              String        @default("ACTIVE") // ACTIVE, INACTIVE, PENDING, SUSPENDED, LOCKED, DELETED
  failedLoginAttempts Int           @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?     @map("locked_until")
  lastLogin           DateTime?     @map("last_login")
  emailVerified       Boolean       @default(false) @map("email_verified")
  phoneVerified       Boolean       @default(false) @map("phone_verified")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  branchId            String?       @map("branch_id")
  branch              Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  userRoles           UserRole[]
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  userSessions        UserSession[]
  loginHistories      LoginHistory[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  orders              Order[]

  @@map("users")
}

model Branch {
  id        String            @id @default(uuid())
  name      String
  code      String            @unique
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  users     User[]
  orders    Order[]
  tables    RestaurantTable[]
  expenses  Expense[]

  @@map("branches")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  device    String?
  browser   String?
  os        String?
  expiresAt DateTime @map("expires_at")
  isValid   Boolean  @default(true) @map("is_valid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  email      String
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  device     String?
  browser    String?
  os         String?
  status     String   // SUCCESS, FAILED, LOCKED
  failReason String?  @map("fail_reason")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("login_history")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  group       String   @default("general")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  device    String?
  browser   String?
  os        String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  entityName String   @map("entity_name")
  entityId   String   @map("entity_id")
  action     String   
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  device     String?
  browser    String?
  os         String?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id         String      @id @default(uuid())
  name       String
  sku        String      @unique
  price      Float
  cost       Float       @default(0)
  stock      Int         @default(0)
  minStock   Int         @default(10) @map("min_stock")
  status     String      @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  categoryId String?     @map("category_id")
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]

  @@map("products")
}

model RestaurantTable {
  id           String        @id @default(uuid())
  name         String
  status       String        @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED, CLEANING
  capacity     Int
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  branchId     String?       @map("branch_id")
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orders       Order[]
  reservations Reservation[]

  @@map("restaurant_tables")
}

model Reservation {
  id              String           @id @default(uuid())
  customerName    String           @map("customer_name")
  customerPhone   String?          @map("customer_phone")
  guests          Int
  reservationTime DateTime         @map("reservation_time")
  status          String           @default("PENDING") // PENDING, CONFIRMED, CANCELLED, SEATED, NOSHOW
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  customerId      String?          @map("customer_id")
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tableId         String?          @map("table_id")
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@map("reservations")
}

model Customer {
  id              String        @id @default(uuid())
  name            String
  email           String?       @unique
  phone           String?
  isLoyaltyMember Boolean       @default(false) @map("is_loyalty_member")
  loyaltyPoints   Int           @default(0) @map("loyalty_points")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  orders          Order[]
  reservations    Reservation[]

  @@map("customers")
}

model Order {
  id              String           @id @default(uuid())
  orderNumber     String           @unique @map("order_number")
  orderType       String           @default("EAT_IN") // EAT_IN, TAKEAWAY, DELIVERY
  status          String           @default("PENDING") // PENDING, PREPARING, READY, SERVED, COMPLETED, CANCELLED, REFUNDED
  paymentStatus   String           @default("UNPAID") // UNPAID, PAID, REFUNDED
  paymentMethod   String?          @map("payment_method") // CASH, CARD, QR, ONLINE
  subtotal        Float
  discount        Float            @default(0)
  tax             Float            @default(0)
  serviceCharge   Float            @default(0) @map("service_charge")
  total           Float
  preparationTime Int?             @map("preparation_time")
  servingTime     Int?             @map("serving_time")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userId          String?          @map("user_id")
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  branchId        String?          @map("branch_id")
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId      String?          @map("customer_id")
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  tableId         String?          @map("table_id")
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  payments        Payment[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  price     Float
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float
  category    String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  branchId    String?  @map("branch_id")
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("expenses")
}

model Payment {
  id        String   @id @default(uuid())
  amount    Float
  method    String
  createdAt DateTime @default(now()) @map("created_at")
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}
